{
  "manifest_version": 3,
  "name": "MeetVcon",
  "version": "0.1.0",
  "description": "Transcribe Google Meet calls using built-in captions and POST the transcript as a vCon to a user-configured webhook.",
  "minimum_chrome_version": "120",

  "permissions": [
    "storage",
    "alarms",
    "identity",
    "identity.email"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": [
        "src/lib/logger.js",
        "src/lib/selectors.js",
        "src/lib/storage.js",
        "src/lib/vcon.js",
        "src/content/captions-watchdog.js",
        "src/content/transcript-capture.js",
        "src/content/in-call-panel.js",
        "src/content/main.js"
      ],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },

  "action": {
    "default_title": "MeetVcon",
    "default_popup": "src/popup/popup.html"
  }
}
